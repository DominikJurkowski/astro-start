---
import Social from "./Social.astro";
import "../styles/global.css";
const platform = "Gitbub";
const username = "WisthAstro";
---
<style>
    footer {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 2rem;
    }
</style>
<footer>
    <p>Learn more about my project on <a href={`https://${platform}.com/${username}`}>{platform}</a></p>

    <div>
        <Social platform={platform} username={username} />
        <Social platform={"twitter"} username={username} />
        <Social platform={"youtube"} username={username} />
    </div>
</footer>