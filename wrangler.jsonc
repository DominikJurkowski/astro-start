{
	"compatibility_date": "2026-06-01",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "astro-start",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "f494d793d17c4b92953c13a20e18d93d"
		}
	]
}